{
  "schema_version": 1,
  "mode": "local_lab",
  "program": {
    "name": "Local training lab",
    "platform": "local",
    "policy_url": "local://owned-training-environment",
    "policy_snapshot_date": "2026-07-23"
  },
  "authorization": {
    "confirmed": true,
    "confirmed_by": "Local environment owner",
    "testing_identity": "local-lab",
    "notes": "Use only for an environment you own or intentionally installed for security training."
  },
  "scope": {
    "allowed_origins": [
      "http://127.0.0.1:3000"
    ],
    "allowed_path_prefixes": [
      "/"
    ],
    "excluded_origins": [],
    "excluded_path_prefixes": [],
    "allowed_methods": [
      "GET",
      "HEAD",
      "OPTIONS",
      "POST"
    ],
    "max_requests_per_minute": 12,
    "max_total_requests_per_case": 100,
    "max_response_bytes": 1048576,
    "follow_redirects": false,
    "allow_private_networks": true,
    "identification_headers": {}
  },
  "safety": {
    "only_owned_test_accounts": true,
    "allow_state_change": true,
    "stop_on_real_user_data": true,
    "stop_on_service_instability": true,
    "prohibited_tests": [
      "denial of service",
      "destructive actions",
      "persistence",
      "automated report submission"
    ]
  },
  "reporting": {
    "human_approval_required": true,
    "auto_submit": false
  }
}
