# OpenCode Agent Loop Configuration
# Copy this file to .env and fill in your values.
# Never commit .env files to version control.

# Path to the OpenCode binary (optional, auto-detected if not set)
# AGENT_LOOP_WORKER_EXECUTABLE=/usr/local/bin/opencode

# Project directory for agent operations (optional, defaults to cwd)
# AGENT_LOOP_PROJECT_DIR=/path/to/your/project

# Maximum recursion depth for agent loop (default: 1)
# AGENT_LOOP_MAX_DEPTH=1

# ntfy notification topic (optional)
# Enable notifications for paid fallback activation
# NTFY_TOPIC=your-notification-topic

# ntfy server URL (optional, defaults to https://ntfy.sh)
# NTFY_SERVER=https://ntfy.sh