diff --git a/packages/opencode/src/tool/task.ts b/packages/opencode/src/tool/task.ts
index c006f3f7c..6746ff1e7 100644
--- a/packages/opencode/src/tool/task.ts
+++ b/packages/opencode/src/tool/task.ts
@@ -22,6 +22,172 @@ export interface TaskPromptOps {
   prompt(input: SessionPrompt.PromptInput): Effect.Effect<SessionV1.WithParts>
 }
 
+interface SubagentFailure {
+  status: "failed"
+  error: {
+    type: "rate_limit" | "api_error" | "auth_error" | "context_overflow" | "content_filter" | "cancelled" | "unknown"
+    provider: string
+    model: string
+    detail: string
+    retryable?: boolean
+    statusCode?: number
+  }
+}
+
+const FAILURE_PREFIX = '{"status":"failed"'
+
+function isFailureOutput(output: string): output is string {
+  return output.startsWith(FAILURE_PREFIX)
+}
+
+function parseFailureOutput(output: string): SubagentFailure | undefined {
+  try {
+    const parsed = JSON.parse(output)
+    if (typeof parsed !== "object" || parsed === null) return undefined
+    if (parsed.status !== "failed") return undefined
+    const err = parsed.error
+    if (typeof err !== "object" || err === null) return undefined
+    if (typeof err.type !== "string") return undefined
+    if (typeof err.provider !== "string") return undefined
+    if (typeof err.model !== "string") return undefined
+    if (typeof err.detail !== "string") return undefined
+    return parsed as SubagentFailure
+  } catch {
+    return undefined
+  }
+}
+
+function classifySubagentFailure(
+  error: unknown,
+  model: { providerID: string; modelID: string },
+): SubagentFailure {
+  const provider = model.providerID
+  const mdl = model.modelID
+
+  if (typeof error !== "object" || error === null) {
+    return {
+      status: "failed",
+      error: { type: "unknown", provider, model: mdl, detail: String(error) },
+    }
+  }
+
+  const record = error as Record<string, unknown>
+  const name = record.name
+  if (typeof name !== "string") {
+    return {
+      status: "failed",
+      error: { type: "unknown", provider, model: mdl, detail: String(error) },
+    }
+  }
+
+  const data = record.data as Record<string, unknown> | undefined
+
+  if (name === "ProviderAuthError") {
+    return {
+      status: "failed",
+      error: {
+        type: "auth_error",
+        provider,
+        model: mdl,
+        detail: typeof data?.message === "string" ? data.message : String(error),
+      },
+    }
+  }
+
+  if (name === "ContextOverflowError") {
+    return {
+      status: "failed",
+      error: {
+        type: "context_overflow",
+        provider,
+        model: mdl,
+        detail: typeof data?.message === "string" ? data.message : String(error),
+      },
+    }
+  }
+
+  if (name === "ContentFilterError") {
+    return {
+      status: "failed",
+      error: {
+        type: "content_filter",
+        provider,
+        model: mdl,
+        detail: typeof data?.message === "string" ? data.message : String(error),
+      },
+    }
+  }
+
+  if (name === "MessageAbortedError") {
+    return {
+      status: "failed",
+      error: {
+        type: "cancelled",
+        provider,
+        model: mdl,
+        detail: typeof data?.message === "string" ? data.message : String(error),
+      },
+    }
+  }
+
+  if (name === "APIError") {
+    const message = typeof data?.message === "string" ? data.message : String(error)
+    const statusCode = typeof data?.statusCode === "number" ? data.statusCode : undefined
+    const isRetryable = typeof data?.isRetryable === "boolean" ? data.isRetryable : true
+
+    const lowerMessage = message.toLowerCase()
+    if (
+      statusCode === 429 ||
+      lowerMessage.includes("rate limit") ||
+      lowerMessage.includes("too many requests") ||
+      lowerMessage.includes("rate increased too quickly")
+    ) {
+      return {
+        status: "failed",
+        error: {
+          type: "rate_limit",
+          provider,
+          model: mdl,
+          detail: message,
+          statusCode,
+          retryable: isRetryable,
+        },
+      }
+    }
+
+    if (statusCode && statusCode >= 500) {
+      return {
+        status: "failed",
+        error: {
+          type: "api_error",
+          provider,
+          model: mdl,
+          detail: message,
+          statusCode,
+          retryable: isRetryable,
+        },
+      }
+    }
+
+    return {
+      status: "failed",
+      error: {
+        type: "api_error",
+        provider,
+        model: mdl,
+        detail: message,
+        ...(statusCode != null ? { statusCode } : {}),
+        retryable: isRetryable,
+      },
+    }
+  }
+
+  return {
+    status: "failed",
+    error: { type: "unknown", provider, model: mdl, detail: String(error) },
+  }
+}
