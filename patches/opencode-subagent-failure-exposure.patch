index 000000000..4b95dbcbe
--- /dev/null
+++ b/packages/opencode/test/cli/run/error-metadata.test.ts
@@ -0,0 +1,93 @@
+import { describe, expect } from "bun:test"
+import { Effect } from "effect"
+import { cliIt } from "../../lib/cli-process"
+
+function asRecord(value: unknown): Record<string, unknown> | undefined {
+  if (!value || typeof value !== "object") return
+  return value as Record<string, unknown>
+}
+
+function errorEvent(stdout: string, parseJsonEvents: (stdout: string) => Array<Record<string, unknown>>) {
+  return parseJsonEvents(stdout).find((event) => event.type === "error")
+}
+
+describe("opencode run --format json error metadata", () => {
+  cliIt.concurrent(
+    "adds rate-limit metadata without removing the raw error",
+    ({ llm, opencode }) =>
+      Effect.gen(function* () {
+        yield* llm.error(400, {
+          error: {
+            message: "Provider error",
+            type: "api_error",
+            code: "rate_limit_exceeded",
+          },
+        })
+
+        const result = yield* opencode.run("test message", { format: "json" })
+        const event = errorEvent(result.stdout, opencode.parseJsonEvents)
+        const raw = asRecord(event?.error)
+
+        opencode.expectExit(result, 1)
+        expect(raw?.name).toBe("APIError")
+        expect(event?.classification).toBe("rate-limit")
+        expect(event?.statusCode).toBe(400)
+        expect(event?.retryAfterMs).toBeUndefined()
+        expect(event?.providerID).toBe("test")
+        expect(event?.modelID).toBe("test-model")
+      }),
+    60_000,
+  )
+
+  cliIt.concurrent(
+    "classifies quota failures",
+    ({ llm, opencode }) =>
+      Effect.gen(function* () {
+        yield* llm.error(402, { error: { message: "Daily quota exceeded", type: "api_error" } })
+
+        const result = yield* opencode.run("test", { format: "json" })
+        const event = errorEvent(result.stdout, opencode.parseJsonEvents)
+
+        opencode.expectExit(result, 1)
+        expect(event?.classification).toBe("quota")
+        expect(event?.statusCode).toBe(402)
+      }),
+    60_000,
+  )
+
+  cliIt.concurrent(
+    "classifies context overflow failures",
+    ({ llm, opencode }) =>
+      Effect.gen(function* () {
+        yield* llm.error(400, { error: { message: "Context window exceeded", type: "api_error" } })
+
+        const result = yield* opencode.run("test", { format: "json" })
+        const event = errorEvent(result.stdout, opencode.parseJsonEvents)
+
+        opencode.expectExit(result, 1)
+        expect(event?.classification).toBe("context-overflow")
+      }),
+    60_000,
+  )
+
+  cliIt.concurrent(
+    "classifies content-filter from serialized provider body",
+    ({ llm, opencode }) =>
+      Effect.gen(function* () {
+        yield* llm.error(400, {
+          error: {
+            message: "Content was filtered",
+            code: "ContentFilterError",
+            type: "api_error",
+          },
+        })
+
+        const result = yield* opencode.run("test message", { format: "json" })
+        const event = errorEvent(result.stdout, opencode.parseJsonEvents)
+
+        opencode.expectExit(result, 1)
+        expect(event?.classification).toBe("content-filter")
+      }),
+    60_000,
+  )
+})
