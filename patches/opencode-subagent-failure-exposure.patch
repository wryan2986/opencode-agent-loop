index 3927f615a..9450fa7da 100644
--- a/packages/opencode/src/cli/cmd/run.ts
+++ b/packages/opencode/src/cli/cmd/run.ts
@@ -87,6 +87,145 @@ function formatRunError(error: unknown) {
   return FormatError(error) ?? FormatUnknownError(error)
 }
 
+function enhanceErrorForJson(error: unknown): Record<string, unknown> {
+  const source = readErrorSource(error)
+  if (!source) return {}
+
+  const result: Record<string, unknown> = {
+    classification: classifyError(source.statusCode, source.text, source.responseHeaders),
+  }
+  if (source.statusCode !== undefined) result.statusCode = source.statusCode
+  if (source.isRetryable !== undefined) result.isRetryable = source.isRetryable
+  if (source.responseHeaders) addRetryAfter(result, source.responseHeaders)
+  if (source.metadata?.providerID) result.providerID = source.metadata.providerID
+  if (source.metadata?.modelID) result.modelID = source.metadata.modelID
+  if (source.providerID) result.providerID = source.providerID
+  if (source.modelID) result.modelID = source.modelID
+  if (source.metadata) result.metadata = source.metadata
+  return result
+}
+
+function readErrorSource(error: unknown) {
+  const record = asRecord(error)
+  if (!record) return
+  const data = asRecord(record.data)
+  const message = typeof data?.message === "string" ? data.message : undefined
+  const name = typeof record.name === "string" ? record.name : undefined
+  const metadata = stringRecord(data?.metadata)
+  const responseBody = typeof data?.responseBody === "string" ? data.responseBody : undefined
+  const text = [name === "APIError" && message ? undefined : name, message, responseBody]
+    .filter((item): item is string => !!item)
+    .join("\n")
+  if (!text) return
+  return {
+    text,
+    statusCode: typeof data?.statusCode === "number" ? data.statusCode : undefined,
+    isRetryable: typeof data?.isRetryable === "boolean" ? data.isRetryable : undefined,
+    responseHeaders: stringRecord(data?.responseHeaders),
+    metadata,
+    providerID:
+      typeof data?.providerID === "string"
+        ? data.providerID
+        : typeof metadata?.providerID === "string"
+          ? metadata.providerID
+          : undefined,
+    modelID:
+      typeof data?.modelID === "string"
+        ? data.modelID
+        : typeof metadata?.modelID === "string"
+          ? metadata.modelID
+          : undefined,
+  }
+}
+
+function addRetryAfter(result: Record<string, unknown>, headers: Record<string, string>) {
+  // Handle retry-after-ms case-insensitively before retry-after
+  const retryAfterMsHeader = Object.entries(headers).find((entry) => entry[0].toLowerCase() === "retry-after-ms")?.[1]
+  if (retryAfterMsHeader) {
+    const value = Number.parseInt(retryAfterMsHeader, 10)
+    if (!Number.isNaN(value)) {
+      result.retryAfterMs = value
+      return
+    }
+  }
+
+  const retryAfter = Object.entries(headers).find((entry) => entry[0].toLowerCase() === "retry-after")?.[1]
+  if (!retryAfter) return
+  if (/^\d+$/.test(retryAfter)) {
+    result.retryAfterMs = Number.parseInt(retryAfter, 10) * 1000
+    return
+  }
+  result.retryAfter = retryAfter
+}
+
+function asRecord(value: unknown): Record<string, unknown> | undefined {
+  if (!value || typeof value !== "object") return
+  return value as Record<string, unknown>
+}
+
+function stringRecord(value: unknown): Record<string, string> | undefined {
+  const record = asRecord(value)
+  if (!record) return
+  const entries = Object.entries(record).filter((entry): entry is [string, string] => typeof entry[1] === "string")
+  if (!entries.length) return
+  return Object.fromEntries(entries)
+}
+
+function classifyError(statusCode: number | undefined, value: string, headers?: Record<string, string>) {
+  const message = value.toLowerCase()
+
+  // Check for known error names that might be serialized
+  const lowerValue = value.toLowerCase()
+  if (lowerValue.includes("contentfiltererror") || lowerValue.includes("content_filter_error") || lowerValue.includes("content filter error")) {
+    return "content-filter"
+  }
+
+  if (
+    statusCode === 429 ||
+    message.includes("rate limit") ||
+    message.includes("rate_limit") ||
+    message.includes("rate-limit") ||
+    message.includes("ratelimit") ||
+    message.includes("too many") ||
+    headers?.["x-ratelimit-remaining"] === "0" ||
+    headers?.["ratelimit-remaining"] === "0" ||
+    !!headers?.["x-ratelimit-reset"] ||
+    !!headers?.["ratelimit-reset"]
+  ) {
+    return "rate-limit"
+  }
+  if (statusCode === 402 || message.includes("quota")) return "quota"
+  if (
+    statusCode === 401 ||
+    statusCode === 403 ||
+    message.includes("auth") ||
+    message.includes("unauthorized") ||
+    message.includes("forbidden") ||
+    message.includes("api key") ||
+    message.includes("invalid token")
+  ) {
+    return "auth"
+  }
+  if (
+    message.includes("context") &&
+    (message.includes("overflow") ||
+      message.includes("too long") ||
+      message.includes("exceeded") ||
+      message.includes("length"))
+  ) {
+    return "context-overflow"
+  }
+  if (
+    message.includes("content filter") ||
+    (message.includes("filter") && (message.includes("blocked") || message.includes("refused")))
+  ) {
+    return "content-filter"
+  }
+  if (statusCode !== undefined && statusCode >= 500) return "provider"
+  if (message.includes("provider") || message.includes("model") || message.includes("api")) return "provider"
+  return "unknown"
+}
+
 async function tool(part: ToolPart) {
   try {
     const { toolInlineInfo } = await import("./run/tool")
@@ -776,12 +915,17 @@ export const RunCommand = effectCmd({
             if (event.type === "session.error") {
