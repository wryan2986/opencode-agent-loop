@@ -0,0 +1,69 @@
+import { isContextOverflow } from "@opencode-ai/llm"
+
+export type FailureCategory =
+  | "rate_limit"
+  | "quota"
+  | "auth_error"
+  | "context_overflow"
+  | "content_filter"
+  | "cancelled"
+  | "empty"
+  | "api_error"
+  | "unknown"
+
+/**
+ * Check if a message indicates rate limiting (TPM, RPM, token, request throttling).
+ * Avoids false positives for context-window exceeded errors by checking
+ * `isContextOverflow` first.
+ */
+export function isRateLimitMessage(message: string): boolean {
+  if (isContextOverflow(message)) return false
+  const lower = message.toLowerCase()
+  return (
+    lower.includes("rate limit") ||
+    lower.includes("rate-limit") ||
+    lower.includes("ratelimit") ||
+    lower.includes("too many requests") ||
+    lower.includes("rate increased too quickly") ||
+    lower.includes("tokens per minute") ||
+    lower.includes("requests per minute") ||
+    lower.includes("too many tokens") ||
+    lower.includes("resource exhausted")
+  )
+}
+
+/**
+ * Check if a message indicates quota/billing/account/free-usage exhaustion.
+ */
+export function isQuotaMessage(message: string): boolean {
+  const lower = message.toLowerCase()
+  return (
+    lower.includes("insufficient_quota") ||
+    lower.includes("insufficient quota") ||
+    lower.includes("quota exceeded") ||
+    lower.includes("usage limit") ||
+    lower.includes("free usage") ||
+    lower.includes("billing") ||
+    lower.includes("subscription") ||
+    lower.includes("freeusagelimiterror") ||
+    lower.includes("gousagelimiterror")
+  )
+}
+
+/**
+ * Check if a message / status code indicates auth/credential failure.
+ */
+export function isAuthMessage(message: string, statusCode?: number): boolean {
+  if (statusCode === 401 || statusCode === 403) return true
+  const lower = message.toLowerCase()
+  return (
+    lower.includes("unauthorized") ||
+    lower.includes("forbidden") ||
+    lower.includes("invalid api key") ||
+    lower.includes("invalid token") ||
+    lower.includes("api key not found") ||
+    lower.includes("authentication")
+  )
+}
+
+export * as ProviderClassify from "./classify"
