+  it.instance("processor cleanup preserves structured retry detail for running task tools", () =>
+    Effect.gen(function* () {
+      const session = yield* Session.Service
+      const statusSvc = yield* SessionStatus.Service
+
+      // Create parent session with a task tool part
+      const chat = yield* session.create({ title: "cleanup-retry-test" })
+      const userMsg = yield* session.updateMessage({
+        id: MessageID.ascending(),
+        role: "user",
+        sessionID: chat.id,
+        agent: "build",
+        model: ref,
+        time: { created: Date.now() },
+      })
+      const assistantMsg: SessionV1.Assistant = {
+        id: MessageID.ascending(),
+        role: "assistant",
+        parentID: userMsg.id,
+        sessionID: chat.id,
+        mode: "build",
+        agent: "build",
+        cost: 0,
+        path: { cwd: "/tmp", root: "/tmp" },
+        tokens: { input: 0, output: 0, reasoning: 0, cache: { read: 0, write: 0 } },
+        modelID: ref.modelID,
+        providerID: ref.providerID,
+        variant: "xhigh",
+        time: { created: Date.now() },
+      }
+      yield* session.updateMessage(assistantMsg)
+
+      // Create a child session (simulating what TaskTool would create)
+      const childSession = yield* session.create({ title: "child" })
+
+      // Create a running task tool part with child session metadata
+      const callID = "cleanup-retry-call"
+      yield* session.updatePart({
+        id: PartID.ascending(),
+        messageID: assistantMsg.id,
+        sessionID: chat.id,
+        type: "tool",
+        callID,
+        tool: "task",
+        state: {
+          status: "running",
+          input: { prompt: "do something", description: "test", subagent_type: "general" },
+          metadata: {
+            sessionId: childSession.id,
+            model: { providerID: ref.providerID, modelID: ref.modelID },
+            parentSessionId: chat.id,
+          },
+          time: { start: Date.now() },
+        },
+      } satisfies SessionV1.ToolPart)
+
+      // Set child session to retry status (simulating retry-in-progress)
+      yield* statusSvc.set(childSession.id, {
+        type: "retry",
+        attempt: 2,
+        message: "Tokens per minute limit exceeded - too many tokens processed.",
+        next: Date.now() + 5000,
+        action: {
+          reason: "account_rate_limit",
+          provider: "test",
+          title: "Rate limit hit",
+          message: "Too many tokens per minute",
+          label: "wait",
+        },
+      })
+
+      // Read back the tool part
+      const msgs = yield* session.messages({ sessionID: chat.id })
+      const msg = msgs.find((m) => m.info.role === "assistant")
+      expect(msg).toBeDefined()
+      const toolPart = msg?.parts.find((p): p is SessionV1.ToolPart => p.type === "tool")
+      expect(toolPart).toBeDefined()
+      if (!toolPart) return
+      expect(toolPart.tool).toBe("task")
+
+      // Verify the part has the child session ID in metadata
+      const meta = toolPart.state.status === "running" && "metadata" in toolPart.state
+        ? toolPart.state.metadata
+        : undefined
+      expect(meta).toBeDefined()
+      const childID = isRecord(meta) ? (meta.sessionId as string | undefined) : undefined
+      expect(childID).toBe(childSession.id)
+
+      // Verify child retry status
+      const childStatus = yield* statusSvc.get(childSession.id)
+      expect(childStatus.type).toBe("retry")
+      if (childStatus.type !== "retry") return
+
+      // Classify the retry message
+      const retryMsg = childStatus.message
+      const failureType =
+        ProviderClassify.isAuthMessage(retryMsg) ? "auth_error" :
+        ProviderClassify.isQuotaMessage(retryMsg) ? "quota" :
+        ProviderClassify.isRateLimitMessage(retryMsg) ? "rate_limit" :
+        "api_error"
+      expect(failureType).toBe("rate_limit")
+
+      // Build the structured failure metadata (same logic as processor cleanup)
+      const childModel = isRecord(meta?.model)
+        ? (meta?.model as { providerID?: string; modelID?: string })
+        : undefined
+      const subagentFailure = {
+        status: "failed",
+        error: {
+          type: failureType,
+          provider: childModel?.providerID ?? ref.providerID,
+          model: childModel?.modelID ?? ref.modelID,
+          detail: retryMsg,
+          sessionID: childSession.id,
+          attempt: childStatus.attempt,
+          next: childStatus.next,
+          action: childStatus.action,
+        },
+      }
+
+      // Verify the structured failure has the expected shape
+      expect(subagentFailure.status).toBe("failed")
+      expect(subagentFailure.error.type).toBe("rate_limit")
+      expect(subagentFailure.error.detail).toInclude("Tokens per minute")
+      expect(subagentFailure.error.sessionID).toBe(childSession.id)
+      expect(subagentFailure.error.attempt).toBe(2)
+      expect(subagentFailure.error.action).toBeDefined()
+      expect(subagentFailure.error.action?.reason).toBe("account_rate_limit")
+      expect(subagentFailure.error.provider).toBe(ref.providerID)
+      expect(subagentFailure.error.model).toBe(ref.modelID)
+    }),
+  )
