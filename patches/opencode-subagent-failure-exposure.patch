+
+/**
+ * Simulates a llama.cpp-compatible SSE response that sends text content
+ * in a format typical of llama.cpp's streaming endpoint.
+ */
+async function llamaCppSSEServer(): Promise<{ server: Server; url: string }> {
+  const server = createServer((_, res) => {
+    res.writeHead(200, { "content-type": "text/event-stream" })
+    res.flushHeaders()
+
+    // Simulate llama.cpp-style streaming with multiple chunks
+    const chunks = [
+      'data: {"choices":[{"delta":{"role":"assistant"},"finish_reason":null,"index":0}],"object":"chat.completion.chunk","model":"test","created":1234567890}\n\n',
+      'data: {"choices":[{"delta":{"content":"Hello"},"finish_reason":null,"index":0}],"object":"chat.completion.chunk","model":"test","created":1234567890}\n\n',
+      'data: {"choices":[{"delta":{"content":" from"},"finish_reason":null,"index":0}],"object":"chat.completion.chunk","model":"test","created":1234567890}\n\n',
+      'data: {"choices":[{"delta":{"content":" llama.cpp!"},"finish_reason":null,"index":0}],"object":"chat.completion.chunk","model":"test","created":1234567890}\n\n',
+      'data: {"choices":[{"delta":{},"finish_reason":"stop","index":0}],"object":"chat.completion.chunk","model":"test","created":1234567890,"usage":{"prompt_tokens":10,"completion_tokens":5,"total_tokens":15}}\n\n',
+      "data: [DONE]\n\n",
+    ]
+
+    let i = 0
+    function sendNext() {
+      if (i >= chunks.length) {
+        res.end()
+        return
+      }
+      res.write(chunks[i])
+      i++
+      // Small delay between chunks to simulate real streaming
+      setTimeout(sendNext, 5)
+    }
+    sendNext()
+  })
+  await new Promise<void>((resolve) => server.listen(0, "127.0.0.1", resolve))
+  const address = server.address()
+  if (!address || typeof address === "string") throw new Error("server did not bind to a TCP port")
+  return { server, url: `http://127.0.0.1:${address.port}` }
+}
+
+/**
+ * Simulates a llama.cpp-compatible SSE response that includes tool calls.
+ */
+async function llamaCppToolServer(): Promise<{ server: Server; url: string }> {
+  const server = createServer((_, res) => {
+    res.writeHead(200, { "content-type": "text/event-stream" })
+    res.flushHeaders()
+
+    const chunks = [
+      'data: {"choices":[{"delta":{"role":"assistant"},"finish_reason":null,"index":0}],"object":"chat.completion.chunk","model":"test","created":1234567890}\n\n',
+      // Tool call
+      'data: {"choices":[{"delta":{"tool_calls":[{"index":0,"id":"call_1","type":"function","function":{"name":"get_weather","arguments":""}}]},"finish_reason":null,"index":0}],"object":"chat.completion.chunk","model":"test","created":1234567890}\n\n',
+      'data: {"choices":[{"delta":{"tool_calls":[{"index":0,"function":{"arguments":"{\\"city\\":\\"Paris\\"}"}}]},"finish_reason":null,"index":0}],"object":"chat.completion.chunk","model":"test","created":1234567890}\n\n',
+      'data: {"choices":[{"delta":{},"finish_reason":"tool_calls","index":0}],"object":"chat.completion.chunk","model":"test","created":1234567890}\n\n',
+      "data: [DONE]\n\n",
+    ]
+
+    let i = 0
+    function sendNext() {
+      if (i >= chunks.length) {
+        res.end()
+        return
+      }
+      res.write(chunks[i])
+      i++
+      setTimeout(sendNext, 5)
+    }
+    sendNext()
+  })
+  await new Promise<void>((resolve) => server.listen(0, "127.0.0.1", resolve))
+  const address = server.address()
+  if (!address || typeof address === "string") throw new Error("server did not bind to a TCP port")
+  return { server, url: `http://127.0.0.1:${address.port}` }
+}
+
+/**
+ * Simulates an SSE server that sends headers but never sends body data.
+ */
+async function hangingSSEServer(): Promise<{ server: Server; url: string }> {
+  const server = createServer((_, res) => {
+    res.writeHead(200, { "content-type": "text/event-stream" })
+    res.flushHeaders()
+    // Never send any data - simulate a stalled upstream
+  })
+  await new Promise<void>((resolve) => server.listen(0, "127.0.0.1", resolve))
+  const address = server.address()
+  if (!address || typeof address === "string") throw new Error("server did not bind to a TCP port")
+  return { server, url: `http://127.0.0.1:${address.port}` }
+}
