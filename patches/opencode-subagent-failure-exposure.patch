+// Regression: llama.cpp-compatible SSE streaming through @ai-sdk/openai-compatible
+// must produce events instead of hanging after the response body is received.
+import { afterEach, expect } from "bun:test"
+import { createServer, type Server } from "node:http"
+import { streamText } from "ai"
+import { LayerNode } from "@opencode-ai/core/effect/layer-node"
+import { CrossSpawnSpawner } from "@opencode-ai/core/cross-spawn-spawner"
+import { Effect } from "effect"
+import { ProviderV2 } from "@opencode-ai/core/provider"
+import { ModelV2 } from "@opencode-ai/core/model"
+import { disposeAllInstances, provideTmpdirInstance } from "../fixture/fixture"
+import { testEffect } from "../lib/effect"
+import { testProviderConfig } from "../lib/test-provider"
+import { Env } from "@/env"
+import { Plugin } from "@/plugin"
+import { Provider, providerHeaderTimeout, sseChunkTimeout } from "@/provider/provider"
+import { ProviderError } from "@/provider/error"
+
+afterEach(async () => {
+  await disposeAllInstances()
+})
+
+const it = testEffect(
+  LayerNode.compile(LayerNode.group([Provider.node, Env.node, Plugin.node, CrossSpawnSpawner.node])),
+)
+
+it.live("uses bounded stream timeouts when custom providers omit them", () =>
+  Effect.sync(() => {
+    expect(sseChunkTimeout(undefined)).toBe(60_000)
+    expect(sseChunkTimeout(500)).toBe(500)
+    expect(providerHeaderTimeout(undefined)).toBe(60_000)
+    expect(providerHeaderTimeout(500)).toBe(500)
+    expect(providerHeaderTimeout(false)).toBe(false)
+  }),
+)
+
+it.live("llama-cpp-style SSE streaming produces text through the openai-compatible path", () =>
+  Effect.gen(function* () {
+    const server = yield* Effect.acquireRelease(
+      Effect.promise(() => llamaCppSSEServer()),
+      (server) => Effect.sync(() => server.server.close()),
+    )
+
+    yield* provideTmpdirInstance(
+      () =>
+        Effect.gen(function* () {
+          const provider = yield* Provider.Service
+          const model = yield* provider.getModel(ProviderV2.ID.make("test"), ModelV2.ID.make("test-model"))
+          const language = yield* provider.getLanguage(model)
+          const result = streamText({
+            model: language,
+            messages: [{ role: "user", content: "hello" }],
+          })
+
+          const text = yield* Effect.promise(async () => {
+            const events: string[] = []
+            for await (const part of result.fullStream) {
+              if (part.type === "text-delta") events.push(part.text)
+              if (part.type === "finish") break
+            }
+            return events.join("")
+          })
+          expect(text).toBe("Hello from llama.cpp!")
+        }),
+      { config: providerConfig(server.url) },
+    )
+  }),
+)
+
+it.live("llama-cpp-style SSE with tool calls produces events through the openai-compatible path", () =>
+  Effect.gen(function* () {
+    const server = yield* Effect.acquireRelease(
+      Effect.promise(() => llamaCppToolServer()),
+      (server) => Effect.sync(() => server.server.close()),
+    )
+
