-              let err = String(props.error.name)
-              if ("data" in props.error && props.error.data && "message" in props.error.data) {
-                err = String(props.error.data.message)
-              }
+              const err =
+                "data" in props.error && props.error.data && "message" in props.error.data
+                  ? String(props.error.data.message)
+                  : String(props.error.name)
               error = error ? error + EOL + err : err
-              if (emit("error", { error: props.error })) continue
+
+              if (args.format === "json") {
+                const enhancedError = enhanceErrorForJson(props.error)
+                if (emit("error", { error: props.error, ...enhancedError })) continue
+              }
+
               UI.error(err)
             }
 
@@ -847,7 +991,8 @@ export const RunCommand = effectCmd({
               variant: args.variant,
             })
             if (result.error) {
-              if (!emit("error", { error: result.error })) UI.error(formatRunError(result.error))
+              const enhancedError = enhanceErrorForJson(result.error)
+              if (!emit("error", { error: result.error, ...enhancedError })) UI.error(formatRunError(result.error))
               process.exitCode = 1
               return
             }
@@ -864,7 +1009,8 @@ export const RunCommand = effectCmd({
             parts: [...files, { type: "text", text: message }],
           })
           if (result.error) {
-            if (!emit("error", { error: result.error })) UI.error(formatRunError(result.error))
+            const enhancedError = enhanceErrorForJson(result.error)
+            if (!emit("error", { error: result.error, ...enhancedError })) UI.error(formatRunError(result.error))
             process.exitCode = 1
             return
           }
